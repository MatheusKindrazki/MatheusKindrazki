JARVIS_API_URL=https://jarvis.kindrazki.dev
JARVIS_API_KEY=

# Resend — contact form delivery (https://resend.com)
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=
# Inbox that receives contact form submissions
CONTACT_TO_EMAIL=matheus@kindrazki.dev
# From: address. Use `onboarding@resend.dev` for local/dev; switch to a
# verified domain sender (e.g. `hello@kindrazki.dev`) in production.
CONTACT_FROM_EMAIL=onboarding@resend.dev
